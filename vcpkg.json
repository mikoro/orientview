{
  "dependencies": [
    "glm",
    "nlohmann-json",
    "pugixml",
    "sdl3",
    "spdlog",
    "fmt",
    {
      "name": "imgui",
      "features": [
        "docking-experimental",
        "sdl3-binding",
        "sdl3-renderer-binding"
      ]
    },
    {
      "name": "ffmpeg",
      "features": [
        "avcodec",
        "avformat",
        "swscale",
        "swresample",
        "nvcodec",
        "x264",
        "x265"
      ]
    }
  ]
}
